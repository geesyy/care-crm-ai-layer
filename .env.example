# Anthropic API key (https://console.anthropic.com/) — never commit the real key
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

PORT=3002

# --- Harness defaults (can be overridden per call) ---
HARNESS_MAX_RETRIES=3
HARNESS_BASE_DELAY_MS=500
HARNESS_TIMEOUT_MS=15000

# --- Incident workflow ---
INCIDENT_MAX_VALIDATION_ITERATIONS=4
